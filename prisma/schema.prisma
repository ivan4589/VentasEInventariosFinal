// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VENDEDOR
  COBRADOR
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(VENDEDOR)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  saleReturns SaleReturn[]

  purchases       Purchase[]
  sales           Sale[]
  payments        Payment[]
  reportHistories ReportHistory[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]
}

model Client {
  id             String     @id @default(cuid())
  fullName       String
  alias          String?
  type           ClientType @default(NORMAL)
  locationId     String
  location       Location   @relation(fields: [locationId], references: [id])
  phone          String?
  additionalInfo String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  sales    Sale[]
  payments Payment[]

  @@map("clients")
}

enum ClientType {
  NORMAL
  ESPECIAL
  CAMINO
}

model Provider {
  id             String             @id @default(cuid())
  companyName    String             @unique // Nombre de la empresa (ej: "Molino Andino")
  contactName    String? // Persona responsable (ej: "Juan Carlos Apolo")
  phone          String?
  email          String?
  products       Product[] // Un proveedor puede tener muchos productos
  purchaseGroups PurchaseProvider[] // Un proveedor puede tener muchas compras
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("providers")
}

model Category {
  id              String           @id @default(cuid())
  name            String           @unique
  subCategories   SubCategory[]
  products        Product[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  purchaseDetails PurchaseDetail[]

  @@map("categories")
}

model SubCategory {
  id         String    @id @default(cuid())
  name       String    @unique
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("sub_categories")
}

// ====== MODELOS EXISTENTES (actualizados) ======
model Product {
  id            String       @id @default(cuid())
  name          String
  description   String?
  providerId    String
  provider      Provider     @relation(fields: [providerId], references: [id])
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  weight        String?

  purchasePrice        Float
  priceNormal          Float
  priceCamino          Float
  priceEspecial        Float
  priceMayorista       Float?
  minQuantityWholesale Int?
  saleReturnDetails    SaleReturnDetail[]

  markupNormal    Float @default(10)
  markupCamino    Float @default(10)
  markupEspecial  Float @default(10)
  markupMayorista Float @default(10)

  stock           Float   @default(0)
  reservedStock   Float   @default(0)
  minStock        Float   @default(0)
  unit            String  @default("UNIDAD")
  reserveQuantity Float   @default(0)
  additionalInfo  String?
  imageUrl        String?

  purchaseDetails PurchaseDetail[]
  saleDetails     SaleDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id           String         @id @default(cuid())
  userId       Int
  user         User           @relation(fields: [userId], references: [id])
  date         DateTime       @default(now())
  status       PurchaseStatus @default(PENDING)
  total        Float          @default(0)
  observations String?
  pdfUrl       String?

  providerGroups PurchaseProvider[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("purchases")
}

model PurchaseProvider {
  id          String                 @id @default(cuid())
  purchaseId  String
  purchase    Purchase               @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  providerId  String
  provider    Provider               @relation(fields: [providerId], references: [id])
  status      PurchaseProviderStatus @default(PENDING)
  total       Float                  @default(0)
  receivedAt  DateTime?
  cancelledAt DateTime?

  details PurchaseDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([purchaseId, providerId])
  @@index([purchaseId])
  @@index([providerId])
  @@map("purchase_providers")
}

model PurchaseDetail {
  id                 String           @id @default(cuid())
  purchaseProviderId String
  purchaseProvider   PurchaseProvider @relation(fields: [purchaseProviderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  quantity  Float
  unitPrice Float
  subtotal  Float

  pricingConfigured    Boolean @default(false)
  priceNormal          Float?
  priceCamino          Float?
  priceEspecial        Float?
  priceMayorista       Float?
  minQuantityWholesale Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseProviderId])
  @@index([productId])
  @@index([categoryId])
  @@map("purchase_details")
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum PurchaseProviderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

model Sale {
  id         String @id @default(cuid())
  saleNumber String @unique

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  date          DateTime      @default(now())
  status        SaleStatus    @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  saleType      SaleType      @default(CASH)

  dueDate DateTime?

  subtotal Float @default(0)
  discount Float @default(0)
  total    Float

  observations    String?
  pdfUrl          String?
  cancelledPdfUrl String?

  details  SaleDetail[]
  payments Payment[]
  returns  SaleReturn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([clientId])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@map("sales")
}

model SaleDetail {
  id String @id @default(cuid())

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Float
  subtotal  Float

  returnedQuantity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  returnDetails SaleReturnDetail[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_details")
}

model SaleReturn {
  id String @id @default(cuid())

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  amount       Float
  observations String?
  createdAt    DateTime @default(now())

  details SaleReturnDetail[]

  @@index([saleId])
  @@index([userId])
  @@map("sale_returns")
}

model SaleReturnDetail {
  id String @id @default(cuid())

  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  saleDetailId String
  saleDetail   SaleDetail @relation(fields: [saleDetailId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Float
  subtotal  Float

  @@index([saleReturnId])
  @@index([saleDetailId])
  @@index([productId])
  @@map("sale_return_details")
}

enum SaleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
}

enum SaleType {
  CASH
  CREDIT
}

model Payment {
  id           String        @id @default(cuid())
  saleId       String
  sale         Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  amount       Float
  method       PaymentMethod
  reference    String?
  receivedAt   DateTime      @default(now())
  observations String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("payments")
}

enum PaymentMethod {
  CASH
  QR
  BANK_TRANSFER
}

model ReportHistory {
  id         String     @id @default(cuid())
  type       ReportType
  title      String
  parameters String?
  fileUrl    String
  userId     Int
  user       User       @relation(fields: [userId], references: [id])
  createdAt  DateTime   @default(now())

  @@map("report_histories")
}

enum ReportType {
  INVENTORY_GENERAL
  INVENTORY_DETAILED
  SALES_REPORT
  COLLECTION_REPORT
}

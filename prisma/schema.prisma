// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VENDEDOR
  COBRADOR
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]
}

model Client {
  id             String     @id @default(cuid())
  fullName       String
  alias          String?
  type           ClientType @default(NORMAL)
  locationId     String
  location       Location   @relation(fields: [locationId], references: [id])
  phone          String?
  additionalInfo String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("clients")
}

enum ClientType {
  NORMAL
  ESPECIAL
  CAMINO
}

model Provider {
  id          String    @id @default(cuid())
  companyName String    @unique // Nombre de la empresa (ej: "Molino Andino")
  contactName String? // Persona responsable (ej: "Juan Carlos Apolo")
  phone       String?
  email       String?
  products    Product[] // Un proveedor puede tener muchos productos
  //purchases   Purchase[] // Un proveedor puede tener muchas compras
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("providers")
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  subCategories SubCategory[]
  products      Product[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("categories")
}

model SubCategory {
  id         String    @id @default(cuid())
  name       String    @unique
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("sub_categories")
}

// ====== MODELOS EXISTENTES (actualizados) ======
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory SubCategory? @relation(fields: [subCategoryId], references: [id])
  weight      String?
  
  // Precios
  purchasePrice Float   // Último precio de compra
  priceNormal   Float
  priceCamino   Float
  priceEspecial Float
  priceMayorista Float?
  
  // Porcentajes de ganancia (referenciales)
  markupNormal    Float @default(10)
  markupCamino    Float @default(10)
  markupEspecial  Float @default(10)
  markupMayorista Float @default(10)
  
  // Stock
  stock       Float @default(0)
  minStock    Float @default(0)
  unit        String @default("UNIDAD")
  reserveQuantity Float @default(0)
  additionalInfo String?
  imageUrl    String?
  
  // Relaciones
  //saleDetails SaleDetail[]
  //inventoryMovements InventoryMovement[]
  purchaseDetails PurchaseDetail[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Purchase {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  status      PurchaseStatus @default(PENDING)
  total       Float
  observations String?
  pdfUrl      String?  // Ruta del PDF generado
  details     PurchaseDetail[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("purchases")
}

model PurchaseDetail {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float
  unitPrice   Float    // Precio de compra en ese momento
  subtotal    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("purchase_details")
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}